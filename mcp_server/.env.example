# Dify MCP Server 配置模板
# 复制本文件为 .env 并填入真实值：cp .env.example .env

# Dify 实例地址（必填）
DIFY_CONSOLE_BASE_URL=http://your-dify-host:9980

# ==================== 认证方式一：邮箱密码自动登录（推荐，Dify 1.14+）====================
# 密码无需 base64 编码，客户端会自动处理
DIFY_EMAIL=your-email@example.com
DIFY_PASSWORD=your-password

# ==================== 认证方式二：Token 直接注入（可选）====================
# 若已有 access_token / csrf_token / refresh_token，可直接填入，跳过登录
# Token 过期后会自动用邮箱密码重新登录并刷新
# DIFY_CONSOLE_TOKEN=
# DIFY_CSRF_TOKEN=
# DIFY_REFRESH_TOKEN=

# ==================== 认证方式三：Session ID（旧版兼容，不推荐）====================
# DIFY_SESSION_ID=
